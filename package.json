{
  "name": "full-stack",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.2.17",
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev:turbopack": "next dev --turbopack",
    "dev": "next dev --webpack",
    "build": "next build",
    "build:test": "cross-env NODE_ENV=test APP_ENV=test next build",
    "build:prod": "cross-env NODE_ENV=production APP_ENV=production next build",
    "start": "next start",
    "start:test": "node scripts/start-test-server.js",
    "start:prod": "node scripts/start-prod-server.js",
    "lint": "eslint .",
    "worker": "cross-env NODE_ENV=production APP_ENV=production npx tsx scripts/start-worker.ts",
    "worker:convert": "cross-env NODE_ENV=production APP_ENV=production npx tsx scripts/start-convert-worker.ts",
    "worker:transcode": "cross-env NODE_ENV=production APP_ENV=production npx tsx scripts/start-transcode-worker.ts",
    "worker:dev": "cross-env NODE_ENV=test APP_ENV=test npx tsx watch scripts/start-worker.ts",
    "worker:bg": "nohup npm run worker > logs/worker.log 2>&1 &",
    "worker:dev:bg": "nohup npm run worker:dev > logs/worker-dev.log 2>&1 &",
    "worker:pm2": "pm2 start ecosystem.config.js --env production",
    "worker:pm2:dev": "pm2 start ecosystem.config.js --env test",
    "worker:pm2:stop": "pm2 stop download-worker",
    "worker:pm2:restart": "pm2 restart download-worker",
    "worker:pm2:logs": "pm2 logs download-worker",
    "remove:worker": "pm2 delete download-worker"
  },
  "dependencies": {
    "@auth/supabase-adapter": "^1.11.1",
    "@aws-sdk/client-s3": "^3.971.0",
    "@mdx-js/loader": "^3.1.0",
    "@next/mdx": "^16.1.2",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-icons": "^1.3.0",
    "@fingerprintjs/fingerprintjs": "^4.4.1",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "@supadata/js": "^1.3.2",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-router": "^1.117.1",
    "@unpic/react": "^1.0.1",
    "alipay-sdk": "^4.14.0",
    "apify-client": "^2.21.0",
    "axios": "^1.11.0",
    "bullmq": "^5.66.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.25",
    "dayjs": "^1.11.13",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "embla-carousel-react": "^8.5.1",
    "framer-motion": "^11.13.1",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "https-proxy-agent": "^7.0.6",
    "ioredis": "^5.9.1",
    "lucide-react": "^0.525.0",
    "markdown-it": "^14.1.0",
    "motion": "^12.18.1",
    "next": "16.1.2",
    "next-auth": "^5.0.0-beta.30",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.4",
    "ogl": "^1.0.11",
    "puppeteer": "^24.2.1",
    "radix-ui": "^1.4.2",
    "react": "^19.0.0",
    "react-awesome-button": "^7.0.5",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^2.0.5",
    "react-icons": "^5.4.0",
    "react-intl-universal": "^2.12.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.7",
    "rehype-highlight": "^7.0.2",
    "rehype-pretty-code": "^0.13.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "resend": "^6.7.0",
    "sharp": "^0.33.5",
    "sonner": "^1.7.1",
    "stripe": "^20.1.2",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.1",
    "yaml": "^2.8.2",
    "youtube-po-token-generator": "^0.6.0",
    "zod": "^3.25.67",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/opencc-js": "^1.0.3",
    "@types/puppeteer": "^7.0.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^7.0.3",
    "opencc-js": "^1.0.5",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.1",
    "tw-animate-css": "^1.2.5",
    "typescript": "^5.8.2"
  }
}
